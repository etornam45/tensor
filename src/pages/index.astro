---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";

const blog = (await getCollection("blog"))
  .filter(post => !post.data.draft);

const projects = (await getCollection("projects"))
  .filter(project => !project.data.draft);

const allpapers = (await getCollection("papers"))
  .filter(paper => !paper.data.draft);

// Combine blog and projects for a unified feed
const recentFeed = [...blog, ...projects]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE + SITE.NUM_PROJECTS_ON_HOMEPAGE);

const papers = await Promise.all(
  allpapers
    .sort((a, b) => new Date(b.data.dateRead).valueOf() - new Date(a.data.dateRead).valueOf())
    .slice(0, SITE.NUM_PAPERS_ON_HOMEPAGE)
    .map(async (item) => {
      const { Content } = await item.render();
      return { ...item, Content };
    })
);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="animate">
      <h4 class="fascinate-regular text-5xl text-black dark:text-white mb-2">
        Hi, I'm <span class="gradient-text decoration-double">Etornam</span>
      </h4>
      <p class="text-black/50 dark:text-white/50 font-medium">Minimalist Engineer & Problem Solver</p>
    </div>
    
    <div class="space-y-16 mt-12">
      <section class="animate">
        <article class="space-y-4 text-justify">
          <p>
            I’m a minimalist, first-principles engineer who loves solving real-world problems. I care less about buzzwords and more about building robust systems that actually solve problems.
          </p>
          <p>
            This is my digital garden where I share my thoughts on engineering, machine learning, and the papers I'm reading.
          </p>
          <p class="mt-8">
            <span class="fascinate-regular text-base">"Ne ènya wò agbe ƒe taɖodzinu la, xexeame katã ɖoa nugbe be yeana wòava eme"</span> <span class="italic text-sm text-black/60 dark:text-white/60"> — Paulo Coelho</span>
          </p>
        </article>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent feed
          </h5>
          <div class="flex gap-3">
             <Link href="/blog">Blog</Link>
             <Link href="/projects">Projects</Link>
          </div>
        </div>
        <ul class="flex flex-col gap-4">
          {recentFeed.map(entry => (
            <li>
              <ArrowCard entry={entry} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Paper Reviews
          </h5>
          <Link href="/papers">
            See all papers
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {papers.map(entry => (
            <li>
              <ArrowCard entry={entry} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-6">
        <div class="flex flex-wrap gap-y-2 items-center justify-between">
          <h5 class="font-semibold text-black dark:text-white">
            Recent projects
          </h5>
          <Link href="/projects">
            See all projects
          </Link>
        </div>
        <ul class="flex flex-col gap-4">
          {projects.map(project => (
            <li>
              <ArrowCard entry={project} />
            </li>
          ))}
        </ul>
      </section>

      <section class="animate space-y-4">
        <h5 class="font-semibold text-black dark:text-white">
          Let's Connect
        </h5>
        <article>
          <p>
            If you want to get in touch with me about something or just to say hi,
            reach out on social media or send me an email.
          </p>
        </article>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map(SOCIAL => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {"/"}
            </li>
          ))}
          <li class="line-clamp-1">
            <Link href={`mailto:${SITE.EMAIL}`} aria-label={`Email ${SITE.NAME}`}>
              {SITE.EMAIL}
            </Link>
          </li>
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>
